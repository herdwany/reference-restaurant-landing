# Production frontend environment example.
# Only public Vite variables belong here.
# Never add APPWRITE_API_KEY or any secret to this file.
# APPWRITE_API_KEY belongs only in Appwrite Function environment variables or local .env.setup.

VITE_APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_BUCKET_ID=
VITE_APPWRITE_DEFAULT_RESTAURANT_SLUG=demo-restaurant
VITE_APPWRITE_CREATE_ORDER_FUNCTION_ID=
VITE_APPWRITE_CREATE_RESERVATION_FUNCTION_ID=
VITE_APPWRITE_CREATE_CLIENT_FUNCTION_ID=
VITE_ENABLE_ANALYTICS=false
